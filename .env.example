# Sandbox root served by the file tools; also holds search_index.json and demo.db.
DATA_DIR=./data

# Port for the streamable HTTP transport (python -m app.server --transport http).
MCP_PORT=8082

# Optional: bind address for the HTTP transport (defaults to 0.0.0.0).
# MCP_HOST=0.0.0.0

# Bearer keys accepted by the HTTP transport, comma-separated (stdio is not
# gated). Same offline default as the sibling services.
MCP_API_KEYS=demo-key
